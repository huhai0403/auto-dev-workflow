{
  "name": "@huhai0403/bmad-workflow-mcp",
  "version": "0.4.0",
  "description": "BMAD automated development workflow as an MCP server",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "bmad-workflow-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:interactive": "node scripts/interactive-test.mjs",
    "test:stability": "node scripts/stability-test.mjs",
    "test:all": "npm run test:unit && npm run test:smoke && npm run test:interactive && npm run test:stability",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "bmad",
    "workflow",
    "cursor"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
